geometry = genformat {
  5 C
  C  H
  1 1  0.0000000000E+00  0.0000000000E+00  0.0000000000E+00
  2 2  0.6287614522E+00  0.6287614522E+00  0.6287614522E+00
  3 2 -0.6287614522E+00 -0.6287614522E+00  0.6287614522E+00
  4 2 -0.6287614522E+00  0.6287614522E+00 -0.6287614522E+00
  5 2  0.6287614522E+00 -0.6287614522E+00 -0.6287614522E+00
}
driver {
}
hamiltonian = dftb {
  scc = Yes
  scctolerance = 1.0e-5
  maxscciterations = 100
  maxangularmomentum {
    c = p
    h = s
  }
  slaterkosterfiles = type2filenames {
    prefix = slakos/origin/mio-1-1/
    separator = -
    suffix = .skf
  }
  filling = fermi {
    temperature [Kelvin] = 300.0
  }
  charge = 0.0
  mixer = simple {
    mixingparameter = 0.05
  }
}
options {
  writedetailedxml = No
  calculateforces = Yes
  writeautotesttag = Yes
  randomseed = 42
}
analysis {
  printforces = Yes
  mullikenanalysis = Yes
  projectstates {
    region {
      atoms = 1:3
      shellresolved = Yes
      label = carbon
    }
    region {
      atoms = 4:5
      label = hydrogen
    }
  }
}
parseroptions {
  parserversion = 14
  writehsdinput = Yes
  stopafterparsing = No
  ignoreunprocessednodes = No
}
